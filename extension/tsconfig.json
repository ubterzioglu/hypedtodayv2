{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "outDir": "dist",
    "rootDir": ".",
    "skipLibCheck": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"]
  },
  "include": ["background/**/*.ts", "content/**/*.ts", "lib/**/*.ts", "popup/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
